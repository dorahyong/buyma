            function reportSSRScriptLoadError(errorType, src) {
                try {
                    var body = JSON.stringify({
                        type: errorType,
                        uri: document.location.href,
                        clientTime: new Date(),
                        error: 'script: ' + src
                    });
                    if (navigator.sendBeacon) {
                        navigator.sendBeacon('/i/v1/ambulance/crash/json', body);
                    } else {
                        if (fetch instanceof Function) {
                            fetch('/i/v1/ambulance/crash/json', {
                                body: body,
                                method: 'POST',
                                keepalive: true
                            });
                        }
                    }
                } catch (e) {}
            }
        </script>
